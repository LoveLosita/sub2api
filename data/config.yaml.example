server:
    host: 0.0.0.0
    port: 8080
    mode: release
database:
    host: postgres
    port: 5432
    user: sub2api
    password: <same-as-POSTGRES_PASSWORD-in-.env>
    dbname: sub2api
    sslmode: disable
redis:
    host: redis
    port: 6379
    password: ""
    db: 0
    enable_tls: false
jwt:
    secret: <same-as-JWT_SECRET-in-.env>
    expire_hour: 24
default:
    user_concurrency: 5
    user_balance: 0
    api_key_prefix: sk-
    rate_multiplier: 1
rate_limit:
    requests_per_minute: 60
    burst_size: 10
timezone: Asia/Shanghai
pricing:
    remote_url: "https://raw.githubusercontent.com/LoveLosita/sub2api/master/data/model_pricing.json"
    update_interval_hours: 8760
