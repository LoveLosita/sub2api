# =============================================================================
# Sub2API Environment Configuration
# =============================================================================

# PostgreSQL
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=<generate-a-random-password>
POSTGRES_DB=sub2api

# Redis (empty = no password)
REDIS_PASSWORD=

# Admin Account (auto-created on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<set-a-strong-password>

# JWT Secret (prevent logout after restart)
JWT_SECRET=<generate-a-random-hex-string>
JWT_EXPIRE_HOUR=24

# TOTP Encryption Key (preserve 2FA after restart)
TOTP_ENCRYPTION_KEY=<generate-a-random-hex-string>

# Server
BIND_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release
RUN_MODE=standard

# Timezone
TZ=Asia/Shanghai
